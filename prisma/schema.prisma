generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String      @id @default(cuid())
  name          String
  description   String
  price         Int // céntimos
  images        String
  category      String
  brand         String
  stock           Int         @default(0)
  featured        Boolean     @default(false)
  stripeProductId String?
  stripePriceId   String?
  availableUntil  DateTime? // null = siempre disponible; si pasa la fecha, se retira de la tienda
  archived        Boolean     @default(false) // borrado lógico: oculto de tienda y panel, conserva historial de pedidos
  catalogSku      String?     @unique // SKU del catálogo si se puso a la venta desde ahí (evita duplicar)
  createdAt       DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]
}

model Order {
  id                String             @id @default(cuid())
  stripeSessionId   String?            @unique
  stripePaymentId   String?
  status            String             @default("pending")
  total             Int // céntimos
  currency          String             @default("eur")
  customerName      String
  customerEmail     String
  customerPhone     String?
  shippingAddress   String
  trackingCode      String?
  estimatedDelivery DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  items             OrderItem[]
  tracking          ShipmentTracking[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Int // céntimos
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model ShipmentTracking {
  id          String   @id @default(cuid())
  orderId     String
  status      String
  description String
  location    String?
  timestamp   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id])
}

model AdminUser {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String
  passwordHash        String? // null until the account is activated (first-login password set)
  role                String    @default("editor") // "admin" | "editor"
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  setupToken          String?   @unique // sha256 of the one-time activation token
  setupTokenExpires   DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  adminEmail String
  action     String // login_success | login_failed | product_create | product_update | product_delete
  targetType String?
  targetId   String?
  detail     String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// Catalogue reservations: a customer expresses interest in a catalogue model
// (not a for-sale Product). No payment is taken now — when the watch becomes
// available the customer is contacted and pays then. The sku/brand are stored
// denormalised (the catalogue itself lives in src/data/catalog.json, not the DB).
model Reservation {
  id            String   @id @default(cuid())
  sku           String
  brand         String
  customerName  String
  customerEmail String
  customerPhone String?
  note          String?
  status        String   @default("pending") // pending | contacted | paid | cancelled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
  @@index([sku])
}

model Settings {
  id                String   @id @default("default")
  ivaPercent        Int      @default(21)
  freeShippingCents Int      @default(10000) // envío gratis a partir de este importe (céntimos)
  shippingCents     Int      @default(599) // coste de envío (céntimos)
  updatedAt         DateTime @updatedAt
}
